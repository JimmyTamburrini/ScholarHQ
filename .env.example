# Server-only secrets. Never expose these in frontend code.
OPENAI_API_KEY=sk-replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-only-if-using-supabase-admin-server-side
DATABASE_URL=postgresql://user:password@host:5432/database
GOOGLE_CLIENT_SECRET=replace-me
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key
SESSION_SECRET=replace-with-long-random-secret
GOOGLE_OAUTH_STATE_SECRET=replace-with-long-random-secret

# Public/frontend-safe configuration.
PUBLIC_APP_URL=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-public-anon-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_CALENDAR_TIME_ZONE=America/Detroit

# Optional runtime settings.
OPENAI_MODEL=gpt-4o-mini
AI_DAILY_TOKEN_LIMIT=50000
NODE_ENV=development
